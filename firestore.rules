rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAnonymous() {
      return request.auth != null &&
             request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userDoc().role;
    }

    function isSupervisor() {
      return role() == 'dg' || role() == 'drh';
    }

    function isChef() {
      return role() == 'chef';
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAnonymous() ||
                    (isAuth() && (request.auth.uid == userId || isSupervisor()));
      allow create, update: if isAuth() && !isAnonymous() && (
        role() == 'drh' ||
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['role', 'directionId', 'matricule', 'status']))
      );
      allow delete: if isAuth() && !isAnonymous() && role() == 'drh';
    }

    // ── directions ─────────────────────────────────────────────────────────
    match /directions/{dirId} {
      allow read:  if isAuth();
      allow write: if isAuth() && !isAnonymous() && role() == 'drh';
    }

    // ── rdj_reports ────────────────────────────────────────────────────────
    match /rdj_reports/{reportId} {
      allow read: if isAnonymous() ||
                    (isAuth() && (
                      isSupervisor() ||
                      request.auth.uid == resource.data.userId ||
                      (isChef() && resource.data.directionId == userDoc().directionId)
                    ));
      allow create: if isAuth() && !isAnonymous() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && !isAnonymous() && (
        resource.data.userId == request.auth.uid ||
        ((isSupervisor() || isChef()) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['signatureCA', 'signatureCST']))
      );
      allow delete: if isAuth() && !isAnonymous() && isSupervisor();
    }

    // ── alerts ─────────────────────────────────────────────────────────────
    match /alerts/{alertId} {
      allow read:  if isAnonymous() ||
                      (isAuth() && (isSupervisor() || isChef()));
      allow write: if isAuth() && !isAnonymous() && role() == 'drh';
    }

    // ── config ─────────────────────────────────────────────────────────────
    match /config/{configId} {
      allow read:  if isAuth();
      allow write: if isAuth() && !isAnonymous() && role() == 'drh';
    }
  }
}
